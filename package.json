{
  "name": "symi",
  "version": "1.1.4",
  "description": "SYMI - 智能家居行业SAAS管理系统，提供项目、库存、工资、预警一体化解决方案",
  "author": "SYMI Team <303316404@qq.com>",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/symi-daguo/smart-home-salary",
  "repository": {
    "type": "git",
    "url": "https://github.com/symi-daguo/smart-home-salary.git"
  },
  "bugs": {
    "url": "https://github.com/symi-daguo/smart-home-salary/issues"
  },
  "keywords": [
    "smart-home",
    "saas",
    "erp",
    "nestjs",
    "react",
    "prisma",
    "warehouse",
    "salary",
    "inventory",
    "tauri"
  ],
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "docker compose -f infra/docker-compose.yml up -d",
    "dev:build": "docker compose -f infra/docker-compose.yml up -d --build",
    "dev:stop": "docker compose -f infra/docker-compose.yml down",
    "dev:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:seed": "cd apps/api && npx prisma db seed",
    "db:studio": "cd apps/api && npx prisma studio",
    "api:dev": "cd apps/api && npm run start:dev",
    "web:dev": "cd apps/web && npm run dev",
    "build": "cd apps/api && npm run build && cd ../web && npm run build",
    "lint": "cd apps/api && npm run lint && cd ../web && npm run lint",
    "test": "cd apps/api && npm test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --ci false"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1"
  }
}
