{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SmartHome",
  "version": "1.2.0",
  "identifier": "com.smarthome.desktop",
  "build": {
    "frontendDist": "../apps/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "cd apps/web && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "智能家居SaaS管理系统",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://localhost:3000 ws://localhost:3000 http://127.0.0.1:3000 ws://127.0.0.1:3000",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'unsafe-inline' 'self'",
        "font-src": "'self' data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "SYMI-DA GUO",
    "category": "Business",
    "shortDescription": "智能家居行业 SaaS 管理系统",
    "longDescription": "专为智能家居行业设计的综合管理系统，涵盖项目管理、工资计算、仓库管理、业务上报等核心功能。",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "wix": {
        "language": "zh-CN",
        "template": "default"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:smarthome.db"]
    }
  }
}
