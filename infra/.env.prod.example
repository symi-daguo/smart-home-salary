## Production environment template (DO NOT COMMIT REAL SECRETS)

# Public URLs
FRONTEND_URL=https://your-domain.example
# Optional: comma-separated origins (if using a separate admin domain). Prefer same-domain reverse proxy.
CORS_ORIGIN=https://your-domain.example

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=salary

# JWT secrets (use long random values; rotate periodically)
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_RANDOM
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_RANDOM

# Swagger (disable in production by default)
SWAGGER_ENABLED=false

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
S3_BUCKET=salary-uploads
S3_PUBLIC_BASE_URL=https://files.your-domain.example/salary-uploads

# OpenClaw Gateway (do NOT expose to public internet)
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=REPLACE_WITH_STRONG_RANDOM

# If using external S3 instead of MinIO, set:
# S3_ENDPOINT=https://s3.<region>.amazonaws.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

