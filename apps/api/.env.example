# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_ACCESS_SECRET=access-secret-change-me-in-production
JWT_REFRESH_SECRET=refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ============================================
# REDIS CACHE
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# BILLING PROVIDER
# Options: stripe, paddle, mock
# ============================================
BILLING_PROVIDER=mock

# Stripe (if BILLING_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Paddle (if BILLING_PROVIDER=paddle)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=sandbox

# ============================================
# EMAIL PROVIDER
# Options: smtp, resend, console
# ============================================
EMAIL_PROVIDER=console

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Resend (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_...
RESEND_FROM=onboarding@resend.dev

# ============================================
# LOGGER
# ============================================
LOG_PROVIDER=pino   # console | pino | winston | loki
LOG_LEVEL=info         # trace | debug | info | warn | error | fatal
LOG_PRETTY=true        # Pretty print (dev mode)

# ============================================
# OBSERVABILITY
# ============================================
LOKI_HOST=http://loki:3100
TRACING_ENABLED=true
OTEL_SERVICE_NAME=saas-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318

# ============================================
# FRONTEND URLs (for email links)
# ============================================
FRONTEND_URL=http://localhost:3001
