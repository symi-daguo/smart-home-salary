{
  "logging": { "level": "info" },
  "agent": {
    "model": "anthropic/claude-opus-4-6",
    "workspace": "~/.openclaw/workspace",
    "thinkingDefault": "high",
    "timeoutSeconds": 1800,
    "heartbeat": { "every": "0m" },
    "skipBootstrap": false
  },
  "config": {
    "apiBase": "http://localhost:3000/api",
    "webBase": "http://localhost:5173",
    "tenantId": "",
    "features": {
      "voiceInput": true,
      "textInput": true,
      "confirmBeforeSubmit": true,
      "showFormSummary": true
    }
  },
  "skills": {
    "registry": "./skills",
    "defaults": [
      "taxonomy-smart-home",
      "employee-skill-router"
    ],
    "roles": {
      "OWNER": {
        "skills": ["admin-guide", "salary-assistant"],
        "default": "salary-assistant"
      },
      "ADMIN": {
        "skills": ["admin-guide", "salary-assistant"],
        "default": "salary-assistant"
      },
      "MEMBER": {
        "skills": ["member-sales", "member-technician", "member-salary"],
        "default": "employee-skill-router"
      }
    }
  },
  "channels": {
    "whatsapp": {
      "allowFrom": [],
      "groups": {
        "*": { "requireMention": true }
      }
    },
    "wechat": {
      "allowFrom": [],
      "requireMention": true
    }
  },
  "routing": {
    "groupChat": {
      "mentionPatterns": ["@symi", "@SYMI", "symi"]
    },
    "errorHandling": {
      "401": "您的登录已过期，请重新登录后再试。",
      "403": "您没有权限执行此操作，请联系管理员。",
      "404": "未找到相关数据，请检查输入是否正确。",
      "422": "数据验证失败：{message}",
      "429": "请求过于频繁，请稍后再试。",
      "500": "服务器暂时不可用，请稍后重试或联系技术支持。",
      "network": "网络连接失败，请检查网络后重试。",
      "timeout": "请求超时，请稍后重试。"
    }
  },
  "session": {
    "scope": "per-sender",
    "resetTriggers": ["/new", "/reset", "重新开始"],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 10080
    }
  },
  "voice": {
    "enabled": true,
    "provider": "default",
    "language": "zh-CN",
    "autoConvertNumbers": true,
    "fuzzyMatchThreshold": 0.8
  },
  "nlu": {
    "currencyParser": {
      "enabled": true,
      "conversions": {
        "万": 10000,
        "千": 1000,
        "百": 100,
        "k": 1000,
        "w": 10000
      }
    },
    "dateParser": {
      "enabled": true,
      "formats": ["YYYY-MM-DD", "MM-DD", "今天", "昨天", "明天", "本周", "本月"]
    }
  }
}
